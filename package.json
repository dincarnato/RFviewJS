{
  "name": "RFview",
  "version": "1.1.1",
  "description": "RFview — RNA Framework Structure Viewer",
  "main": "main.js",
  "author": {
    "name": "Danny Incarnato",
    "email": "dincarnato@rnaframework.com"
  },
  "homepage": "https://github.com/dincarnato/RFviewJS",
  "license": "GPLv3",
  "scripts": {
    "start": "electron-forge start",
    "start:dev": "NODE_ENV=development electron .",
    "pack": "electron-builder --dir",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "electron": "^42.3.0"
  },
  "build": {
    "appId": "com.rfviewjs.desktop",
    "productName": "RFview",
    "artifactName": "RFview-${version}-${arch}.${ext}",
    "copyright": "IncaRNAto lab 2026",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "scripts/**/*",
      "!scripts/**/*.map"
    ],
    "mac": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "darkModeSupport": true,
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Science",
      "icon": "assets/icon.png"
    },
    "publish": null
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  }
}
